# Terra Mensa — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# USDA MARS API key (required for Indiana auction data)
# Sign up at https://marsapi.ams.usda.gov
MARS_API_KEY=

# PostgreSQL connection (local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=terra_mensa
DB_USER=              # your postgres username
DB_PASSWORD=          # leave blank if using peer/trust auth

# Supabase (production)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_DB_HOST=              # aws-0-REGION.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=              # postgres.YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=
