# Multi-Species Valuation Engine — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# USDA MARS API key (required for Indiana auction data)
# Sign up at https://marsapi.ams.usda.gov
MARS_API_KEY=

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cattle_valuation
DB_USER=              # your postgres username
DB_PASSWORD=          # leave blank if using peer/trust auth
